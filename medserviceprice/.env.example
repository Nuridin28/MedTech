# Copy to .env and adjust. Never commit the real .env (TZ §11).

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Postgres ---
POSTGRES_USER=msp
POSTGRES_PASSWORD=msp_password
POSTGRES_DB=medserviceprice
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Security ---
# Change this; the admin parse/normalize endpoints require it as X-API-Key.
ADMIN_API_KEY=change-me-in-prod
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:80

# --- Search ---
# Lexical (pg_trgm) is always on. To enable semantic/hybrid, install
# requirements-semantic.txt in the image and set this to true.
ENABLE_SEMANTIC=false
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Parser etiquette (TZ §5.4) ---
PARSER_DELAY_SECONDS=1.5
PARSER_MAX_RETRIES=3
FX_USD_KZT_FALLBACK=470

# --- Data freshness (TZ §4) — offers older than this are hidden as stale ---
STALE_AFTER_DAYS=30

# --- File uploads (TZ §3.1) — shared volume between backend & worker ---
UPLOAD_DIR=/app/data/uploads

# --- Geocoding (TZ §3.4 map) — OSM Nominatim, public, no key needed ---
GEOCODE_ENABLED=true

# --- Places API (clinic ratings / reviews / photos) — official, OFF by default ---
# Clinic metadata + primary photo are always enriched for free from each clinic's
# own structured data (JSON-LD/OpenGraph). Ratings & reviews require an official
# provider below (never scraped from maps). Leave provider=none to keep it off.
PLACES_PROVIDER=none          # none | 2gis | google
TWOGIS_API_KEY=
GOOGLE_PLACES_KEY=

# --- Email price-drop alerts (TZ §3.4) — optional. Leave SMTP_HOST empty to
# just log notifications (feature still works end-to-end without a mail server).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MedServicePrice.kz <noreply@medserviceprice.kz>
SMTP_TLS=true
