# Copy to .env and adjust. Never commit the real .env (TZ §11).

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Postgres ---
POSTGRES_USER=msp
POSTGRES_PASSWORD=msp_password
POSTGRES_DB=medserviceprice
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Security ---
# Change this; the admin parse/normalize endpoints require it as X-API-Key.
ADMIN_API_KEY=change-me-in-prod
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:80

# --- Search ---
# Lexical (pg_trgm) is always on. To enable semantic/hybrid, install
# requirements-semantic.txt in the image and set this to true.
ENABLE_SEMANTIC=false
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Parser etiquette (TZ §5.4) ---
PARSER_DELAY_SECONDS=1.5
PARSER_MAX_RETRIES=3
FX_USD_KZT_FALLBACK=470

# --- Data freshness (TZ §4) — offers older than this are hidden as stale ---
STALE_AFTER_DAYS=30

# --- File uploads (TZ §3.1) — shared volume between backend & worker ---
UPLOAD_DIR=/app/data/uploads

# --- Operational alerts ---
# Email to receive alerts (parse failed / 0 records / stale source). Empty = log only.
# Alerts also show as a banner in /admin regardless of email.
ALERT_EMAIL=
SOURCE_STALE_HOURS=48

# --- Observability / ELK ---
# JSON logs always go to stdout. Set ELASTIC_ENABLED=true to ALSO ship them to
# Elasticsearch so the admin "Логи" panel and Kibana work. docker-compose already
# wires these for backend/worker/beat; override here for local (non-Docker) runs.
ELASTIC_ENABLED=false
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTIC_INDEX=msp-logs
ELASTIC_USER=
ELASTIC_PASSWORD=
KIBANA_URL=http://localhost:5601

# --- Geocoding (TZ §3.4 map) — OSM Nominatim, public, no key needed ---
GEOCODE_ENABLED=true

# --- Places API (clinic ratings / reviews / photos) — official, OFF by default ---
# Clinic metadata + primary photo are always enriched for free from each clinic's
# own structured data (JSON-LD/OpenGraph). Ratings & reviews require an official
# provider below (never scraped from maps). Leave provider=none to keep it off.
PLACES_PROVIDER=none          # none | 2gis | google  — ratings/reviews/address
PLACES_PHOTO_PROVIDER=none    # none | google | 2gis  — clinic photo (run separately)
# Recommended hybrid: 2GIS for ratings/reviews (best KZ coverage, 1000-req key),
# Google for photos (generous $200/mo credit, stable image URLs, no key exposure):
#   PLACES_PROVIDER=2gis  PLACES_PHOTO_PROVIDER=google
TWOGIS_API_KEY=
GOOGLE_PLACES_KEY=
# Quota guards: each clinic is looked up at most ONCE ever (cached in DB). With a
# 1000-request key, one full pass over ~191 clinics costs ~191 and re-runs cost 0.
# PLACES_MAX_PER_RUN bounds a single enrich run; raise it to enrich faster.
PLACES_BUDGET=1000
PLACES_MAX_PER_RUN=50

# --- Email price-drop alerts (TZ §3.4) — optional. Leave SMTP_HOST empty to
# just log notifications (feature still works end-to-end without a mail server).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MedServicePrice.kz <noreply@medserviceprice.kz>
SMTP_TLS=true

# --- AI assistant (domain-scoped chatbot) — OFF by default ---
# Set ASSISTANT_ENABLED=true AND provide OPENAI_API_KEY to turn it on. The key stays
# on the backend only (never shipped to the browser). Every call passes through the
# safety gateway (app/services/assistant.py): it validates the user prompt AND the
# model reply (moderation + scope classifier + prompt-leak check) and answers ONLY
# questions about this service. The widget hides itself when this is off.
ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_OUTPUT_TOKENS=500
# Abuse / cost guards
ASSISTANT_MAX_INPUT_CHARS=1000
ASSISTANT_MAX_HISTORY=6
ASSISTANT_RATE_PER_MINUTE=12      # per-IP burst
ASSISTANT_RATE_PER_DAY=200        # per-IP daily
ASSISTANT_DAILY_BUDGET_CALLS=5000 # global OpenAI call ceiling per day
